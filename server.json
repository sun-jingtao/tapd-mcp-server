{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.sun-jingtao/tapd-mcp-server",
  "title": "TAPD MCP Server",
  "description": "在 Cursor/Copilot 中查询、分析和回填 TAPD bug / 需求",
  "repository": {
    "url": "https://github.com/sun-jingtao/tapd-mcp-server",
    "source": "github"
  },
  "websiteUrl": "https://github.com/sun-jingtao/tapd-mcp-server#readme",
  "icons": [
    {
      "src": "https://unpkg.com/tapd-mcp-server@1.0.4/icon.png",
      "mimeType": "image/png",
      "sizes": [
        "512x512"
      ]
    }
  ],
  "version": "1.0.4",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "tapd-mcp-server",
      "version": "1.0.4",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "TAPD_ACCESS_TOKEN",
          "description": "TAPD 个人访问令牌",
          "isRequired": true,
          "isSecret": true
        }
      ]
    }
  ]
}
